  "block.createaddon.guidance_computer.tooltip.summary": "读取附近制导传感器的数值，并为闭环机械结构输出控制指令。",
  "block.createaddon.guidance_computer.tooltip.condition1": "靠近传感器放置时",
  "block.createaddon.guidance_computer.tooltip.behaviour1": "自动订阅扫描范围内的 ISensor，并读取其 double、Vec3 或 boolean 数值源。",
  "block.createaddon.guidance_computer.tooltip.condition2": "贴地巡航时",
  "block.createaddon.guidance_computer.tooltip.behaviour2": "组合地形高度、方位误差、漂移角、接近速率与结构应力，计算升降舵、方向舵和油门指令。",
  "block.createaddon.guidance_computer.tooltip.control1": "悬停时按住 [W]",
  "block.createaddon.guidance_computer.tooltip.action1": "打开思索场景，查看机械式传感器总线的工作方式。",
  "block.createaddon.relative_bearing_sensor.tooltip.summary": "测量本结构与目标点或实体之间的有符号偏航角误差。",
  "block.createaddon.relative_bearing_sensor.tooltip.condition1": "输出",
  "block.createaddon.relative_bearing_sensor.tooltip.behaviour1": "返回 -180 到 +180 度。0 表示正对目标。",
  "block.createaddon.relative_bearing_sensor.tooltip.condition2": "用途",
  "block.createaddon.relative_bearing_sensor.tooltip.behaviour2": "用于自动舵面、炮塔瞄准和天线对准。",
  "block.createaddon.closing_speed_sensor.tooltip.summary": "沿目标视线方向测量相对接近速度。",
  "block.createaddon.closing_speed_sensor.tooltip.condition1": "输出",
  "block.createaddon.closing_speed_sensor.tooltip.behaviour1": "返回米每秒。正值表示接近，负值表示远离。",
  "block.createaddon.closing_speed_sensor.tooltip.condition2": "用途",
  "block.createaddon.closing_speed_sensor.tooltip.behaviour2": "用于末端减速、对接限速和引信预判。",
  "block.createaddon.terrain_altimeter.tooltip.summary": "铜制表盘式测深仪，测量结构下方净空。",
  "block.createaddon.terrain_altimeter.tooltip.condition1": "地形模式",
  "block.createaddon.terrain_altimeter.tooltip.behaviour1": "向下射线检测，并返回到第一个可碰撞表面的距离。",
  "block.createaddon.terrain_altimeter.tooltip.condition2": "海平面模式",
  "block.createaddon.terrain_altimeter.tooltip.behaviour2": "返回相对维度海平面的高度，适合舰船与飞艇控制。",
  "block.createaddon.inertial_drift_sensor.tooltip.summary": "对比期望航向与实际水平位移方向，输出侧滑。",
  "block.createaddon.inertial_drift_sensor.tooltip.condition1": "输出",
  "block.createaddon.inertial_drift_sensor.tooltip.behaviour1": "返回有符号漂移角，单位为度。",
  "block.createaddon.inertial_drift_sensor.tooltip.condition2": "用途",
  "block.createaddon.inertial_drift_sensor.tooltip.behaviour2": "用于抑制船舶、飞艇和悬浮载具的横滑。",
  "block.createaddon.lock_on_probability_sensor.tooltip.summary": "根据距离、角度和目标横向速度估算目标质量。",
  "block.createaddon.lock_on_probability_sensor.tooltip.condition1": "输出",
  "block.createaddon.lock_on_probability_sensor.tooltip.behaviour1": "返回 0 到 1 的概率，而不是硬性的红石式锁定。",
  "block.createaddon.lock_on_probability_sensor.tooltip.condition2": "用途",
  "block.createaddon.lock_on_probability_sensor.tooltip.behaviour2": "用于发射授权、火控逻辑和自动拦截器。",
  "block.createaddon.structural_stress_sensor.tooltip.summary": "监测机械与惯性负载，保护脆弱的移动结构。",
  "block.createaddon.structural_stress_sensor.tooltip.condition1": "输出",
  "block.createaddon.structural_stress_sensor.tooltip.behaviour1": "根据网络负载、线速度、转速和加速度尖峰返回 0 到 1 的危险等级。",
  "block.createaddon.structural_stress_sensor.tooltip.condition2": "用途",
  "block.createaddon.structural_stress_sensor.tooltip.behaviour2": "用于过载切断、自动减速和安全模式触发。",
  "block.createaddon.relative_velocity_vector_sensor.tooltip.summary": "为高级导航算法输出完整的目标相对速度矢量。",
  "block.createaddon.relative_velocity_vector_sensor.tooltip.condition1": "输出",
  "block.createaddon.relative_velocity_vector_sensor.tooltip.behaviour1": "返回目标速度减自身速度的 Vec3，保留横向与垂直分量。",
  "block.createaddon.relative_velocity_vector_sensor.tooltip.condition2": "用途",
  "block.createaddon.relative_velocity_vector_sensor.tooltip.behaviour2": "用于比例导引、提前量追踪和对接控制。",
  "block.createaddon.laser_range_finder.tooltip.summary": "黄铜炮管式测距仪，射程随转速增加而延长。",
  "block.createaddon.laser_range_finder.tooltip.condition1": "速度缩放",
  "block.createaddon.laser_range_finder.tooltip.behaviour1": "最大射程 = 转速 × 0.5 格。256 RPM 时波束可达 128 格。",
  "block.createaddon.laser_range_finder.tooltip.condition2": "用途",
  "block.createaddon.laser_range_finder.tooltip.behaviour2": "用于高度保持、地形轮廓测绘和多传感器接近速率验证。",
  "block.createaddon.radar_indexer.tooltip.summary": "旋转抛物面扫描器，定位最近的实体或方块坐标。",
  "block.createaddon.radar_indexer.tooltip.condition1": "输出",
  "block.createaddon.radar_indexer.tooltip.behaviour1": "返回目标位置 Vec3。右击可切换扫描模式。",
  "block.createaddon.radar_indexer.tooltip.condition2": "用途",
  "block.createaddon.radar_indexer.tooltip.behaviour2": "用于雷达制导锁定、航点追踪和区域监视。",
