  "createaddon.ponder.tag.guidance_control": "制导与控制",
  "createaddon.ponder.tag.guidance_control.description": "用于导航、火控和闭环机械结构的机械仪表",
  "createaddon.ponder.tag.sensor_inputs": "传感器输入",
  "createaddon.ponder.tag.sensor_inputs.description": "向制导计算机提供 double、Vec3 或 boolean 测量值的方块",
  "createaddon.ponder.guidance_computer.header": "使用制导计算机",
  "createaddon.ponder.guidance_computer.text_0": "制导计算机会扫描附近的传感器方块，并订阅它们的 IValueProvider 输出。",
  "createaddon.ponder.guidance_computer.text_1": "贴地巡航回路可以组合高度、方位、漂移、接近速率和应力，生成方向舵、升降舵和油门指令。",
  "createaddon.ponder.relative_bearing_sensor.header": "相对方位仪",
  "createaddon.ponder.relative_bearing_sensor.text_0": "比较载具当前航向与目标视线方向。",
  "createaddon.ponder.relative_bearing_sensor.text_1": "输出为 -180 到 +180 度的偏航误差；0 表示完全对准。",
  "createaddon.ponder.relative_bearing_sensor.text_2": "可用于自动方向舵、炮塔传动和天线指向。",
  "createaddon.ponder.closing_speed_sensor.header": "接近速率仪",
  "createaddon.ponder.closing_speed_sensor.text_0": "将相对速度投影到目标视线方向。",
  "createaddon.ponder.closing_speed_sensor.text_1": "正值表示正在接近目标；负值表示距离正在拉开。",
  "createaddon.ponder.closing_speed_sensor.text_2": "可用于末端减速、引信时机和对接限速器。",
  "createaddon.ponder.terrain_altimeter.header": "地形高度计",
  "createaddon.ponder.terrain_altimeter.text_0": "从仪表本体向下发出机械测深射线。",
  "createaddon.ponder.terrain_altimeter.text_1": "地形模式测量到下方第一个碰撞面的距离；海平面模式报告相对海平面的高度。",
  "createaddon.ponder.terrain_altimeter.text_2": "可用于贴地飞行、掠海飞行和安全悬停限制。",
  "createaddon.ponder.inertial_drift_sensor.header": "惯性漂移仪",
  "createaddon.ponder.inertial_drift_sensor.text_0": "比较期望航向与实际水平位移方向。",
  "createaddon.ponder.inertial_drift_sensor.text_1": "输出为有符号侧滑角，即使载具朝向和滑行方向不同也能工作。",
  "createaddon.ponder.inertial_drift_sensor.text_2": "可用于抑制飞艇漂移、船舶横滑和横向过冲。",
  "createaddon.ponder.lock_on_probability_sensor.header": "锁定概率传感器",
  "createaddon.ponder.lock_on_probability_sensor.text_0": "将距离、角度误差和目标横向速度合成为一个火控评分。",
  "createaddon.ponder.lock_on_probability_sensor.text_1": "输出范围为 0 到 1，并保持概率含义，而不是简单的开关。",
  "createaddon.ponder.lock_on_probability_sensor.text_2": "可用于发射许可、火炮控制和拦截器逻辑。",
  "createaddon.ponder.structural_stress_sensor.header": "结构应力传感器",
  "createaddon.ponder.structural_stress_sensor.text_0": "监测动力网络负载、线速度、轴转速和加速度尖峰。",
  "createaddon.ponder.structural_stress_sensor.text_1": "输出为 0 到 1 的危险等级，和普通速度表不同。",
  "createaddon.ponder.structural_stress_sensor.text_2": "可用于过载保护、自动限速和安全模式切断。",
  "createaddon.ponder.relative_velocity_vector_sensor.header": "相对速度矢量传感器",
  "createaddon.ponder.relative_velocity_vector_sensor.text_0": "输出目标速度减去本机速度得到的完整 Vec3。",
  "createaddon.ponder.relative_velocity_vector_sensor.text_1": "不同于接近速率，它保留横向和垂直分量，适合高级拦截算法。",
  "createaddon.ponder.relative_velocity_vector_sensor.text_2": "可用于比例导引、提前量追踪和对接控制。",
  "createaddon.ponder.laser_range_finder.header": "激光测距仪",
  "createaddon.ponder.laser_range_finder.text_0": "沿传感器轴方向发射波束，射程与输入的转速成正比。",
  "createaddon.ponder.laser_range_finder.text_1": "在 Create 最大转速（256 RPM）下波束可达 128 格。较低转速会缩短作用距离。",
  "createaddon.ponder.laser_range_finder.text_2": "可用于地形轮廓测绘、高度保持和多传感器接近速率验证。",
  "createaddon.ponder.radar_indexer.header": "雷达索引器",
  "createaddon.ponder.radar_indexer.text_0": "旋转抛物面扫描器，搜索区域内的实体或方块坐标。",
  "createaddon.ponder.radar_indexer.text_1": "默认模式返回最近生物位置（Vec3）。右击切换扫描模式。",
  "createaddon.ponder.radar_indexer.text_2": "可用于雷达制导锁定、航点追踪和区域监视。",
