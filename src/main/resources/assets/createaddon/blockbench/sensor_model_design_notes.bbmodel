  "name": "sensor_model_design_notes",
  "geometry_name": "sensor_model_design_notes",
  "resolution": { "width": 16, "height": 16 },
  "notes": "The in-game sensor models are complete independent Minecraft block JSON models, not shared multipart overlays. No face uses cullface, so contact faces against adjacent blocks or adjacent model elements remain visible. Designs: relative bearing = compass repeater/yoke, closing speed = twin rangefinder tubes, terrain altimeter = downward sonar bell, inertial drift = gyroscope cage, lock-on probability = optical seeker head, structural stress = strain clamp, relative velocity vector = three-axis resolver.",
  "elements": [
    { "name": "bearing_compass_reference", "from": [1.5, 6.7, 7.25], "to": [14.5, 7.35, 8.75], "color": 1 },
    { "name": "closing_speed_twin_tube_reference", "from": [2, 6, 3], "to": [5, 10, 13], "color": 2 },
    { "name": "altimeter_sonar_bell_reference", "from": [5, -1, 5], "to": [11, 1, 11], "color": 2 },
    { "name": "drift_gyro_ring_reference", "from": [2, 8, 7], "to": [14, 9, 9], "color": 1 },
    { "name": "lock_on_optics_reference", "from": [6, 7, 1], "to": [10, 11, 6], "color": 5 },
    { "name": "stress_strain_clamp_reference", "from": [1, 3, 2], "to": [3, 14, 4], "color": 6 },
    { "name": "velocity_vector_axis_reference", "from": [3, 7, 7.25], "to": [13, 8, 8.75], "color": 1 }
  ],
  "outliner": ["bearing_compass_reference", "closing_speed_twin_tube_reference", "altimeter_sonar_bell_reference", "drift_gyro_ring_reference", "lock_on_optics_reference", "stress_strain_clamp_reference", "velocity_vector_axis_reference"]
